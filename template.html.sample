<!DOCTYPE html>
<html lang="ja">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf8">
<meta name="viewport" content="width=device-width">
	<title>Reject mails</title>
<style>
table {
	border: 1px solid;
	border-collapse: collapse;
}
th, td {
	border:  1px solid;
	padding: 1px 4px;
}
</style>
</head>
<body>

<h1>Reject mails</h1>

<table id="list">
<thead>
<tr>
	<th>Date</th>
	<th>From</th>
	<th>To</th>
	<th>Subject</th>
	<th>DL</th>
</tr>
</thead>
<tbody>
<!--line-start-->
<tr>
	<td><a href="<@txt>"><@date></a></td>
	<td><@from></td>
	<td><@to></td>
	<td><@subject></td>
	<td><a href="<@eml>">.eml</a></td>
</tr>
<!--line-end-->
</tbody>
</table>

</body>
</html>
